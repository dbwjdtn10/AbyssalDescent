; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Abyssal Descent"
config/description="AI 던전 마스터가 이끄는 3D 로그라이크 던전 크롤러"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"
config/name_localized/ko="심연의 강림"

[autoload]

EventBus="*res://scripts/systems/event_bus.gd"
AIClient="*res://scripts/ai/ai_client.gd"
GameManager="*res://scripts/systems/game_manager.gd"
QuestManager="*res://scripts/systems/quest_manager.gd"
DifficultyManager="*res://scripts/systems/difficulty_manager.gd"
PlayerTracker="*res://scripts/systems/player_tracker.gd"
InventorySystem="*res://scripts/systems/inventory_system.gd"
SoundManager="*res://scripts/systems/sound_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

